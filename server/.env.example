# --- Database ---
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/garuda_urbanlines

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_here

# --- Email (Brevo / Resend) ---
BREVO_SENDER_EMAIL=your_email@example.com
BREVO_API_KEY=your_brevo_api_key_here

# --- CORS: set this to your Railway frontend URL (same service = same URL) ---
# For a single-service deployment (server serves client dist), FRONTEND_URL is the Railway URL
FRONTEND_URL=https://your-app-name.railway.app

# --- PORT: Railway sets this automatically, but default is 5000 ---
PORT=5000
